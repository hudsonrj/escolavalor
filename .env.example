WEIGHT_OLIMPIADAS=0.25
WEIGHT_APROVACAO=0.25
WEIGHT_IDEB=0.15

# API
PORT=3005
API_KEY_SALT=change-me-to-random-32-bytes-hex

# Alertas (opcional)
ALERT_WEBHOOK_URL=
