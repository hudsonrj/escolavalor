# Banco de dados
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/escolavalor
REDIS_URL=redis://localhost:6379

# Crawler
CRAWLER_CONCURRENCY=10
CRAWLER_TIMEOUT_PAGE=30000
