{
  "name": "escolavalor-br",
  "version": "0.1.0",
  "description": "API open source que rastreia escolas brasileiras e compara custo-benefício",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/scripts/seed.ts",
    "db:seed-completo": "bun src/scripts/seed-completo.ts",
    "score:recalculate": "bun src/scripts/recalculate-scores.ts",
    "escolas:buscar": "bun src/scripts/buscar-escolas-inep.ts",
    "escolas:atualizar": "bun src/scripts/atualizar-dados-escolas.ts",
    "rotina:madrugada": "bun src/scripts/rotina-madrugada.ts",
    "cron:instalar": "./instalar-cron.sh",
    "crawler": "bun src/crawler/runner.ts",
    "test": "bun test",
    "test:integration": "bun test --integration",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scalar/hono-api-reference": "^0.5.148",
    "better-auth": "^1.0.7",
    "drizzle-orm": "^0.31.4",
    "groq-sdk": "^1.1.2",
    "hono": "^4.6.14",
    "pgvector": "^0.2.1",
    "playwright": "^1.44.1",
    "postgres": "^3.4.4",
    "redis": "^4.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "drizzle-kit": "^0.22.8",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
